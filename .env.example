# Local (TCP)
DATABASE_URL="mysql://root:password@localhost:3306/lostfound_db"

# Local macOS MySQL 8.4+ / 9.x (caching_sha2_password — requires socket)
# DATABASE_URL="mysql://root:password@localhost/lostfound_db?socket=/tmp/mysql.sock"

# Hostinger / remote MySQL (TCP — DO NOT add ?socket= here)
# DATABASE_URL="mysql://db_user:db_pass@your-db-host:3306/db_name"

AUTH_SESSION_SECRET=change-this-session-secret

# PENTING: Set ke path absolut di LUAR folder app agar gambar tidak hilang saat redeploy.
# Hostinger Node.js: gunakan path di luar direktori deployment, misalnya:
# UPLOAD_DIR=/home/u387036946/uploads
#
# Lokal (default, tidak persistent di production):
UPLOAD_DIR=public/uploads
